# .menu-map.env — mapeamento de menus WordPress
# Fonte canônica → Targets (locais Docker-dev ou remotos SSH)
#
# Local: SITE_N_PATH_SYNC = caminho do site docker-dev
#   → script lê .env do site para COMPOSE_STACK_NAME (container) e WP_HOME (URL)
#   → SITE_N_WP_URL sobrescreve WP_HOME (necessário para subsites multisite)
#
# Remoto: SITE_N_PATH_SYNC = hostname do ~/.ssh/config
#   → requer SITE_N_WP_PATH (caminho do WP no servidor remoto)
#   → requer SITE_N_WP_URL (URL pública do site)
#
# ID vazio    → target pulado silenciosamente
# ID definido → deve existir no WordPress (erro fatal se não encontrado)
# Use: std sync setup --target=N  para listar e selecionar IDs

# FONTE site principal
SITE_PATH_FROM=/Users/dcambria/scripts/server-tools/v2/docker-dev/sites/concertacao
HEADER_ID_FROM=3
FOOTER_ID_FROM=1787


# TARGET 2 — totem /cultura/
SITE_2_PATH_SYNC=/Users/dcambria/scripts/server-tools/v2/docker-dev/sites/concertacao
SITE_2_WP_URL=https://cambrasmax.local:8484/cultura/
HEADER_2_ID_TO=2473
FOOTER_2_ID_TO=16

