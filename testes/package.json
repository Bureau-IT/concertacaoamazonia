{
  "name": "concertacao-playwright-tests",
  "version": "1.0.0",
  "description": "Suite de testes Playwright — concertacaoamazonia.com.br",
  "scripts": {
    "test": "playwright test",
    "test:smoke": "playwright test tests/01-pages-smoke.spec.js",
    "test:console": "playwright test tests/02-console-errors.spec.js",
    "test:gtm": "playwright test tests/03-gtm.spec.js",
    "test:downloads": "playwright test tests/04-downloads.spec.js",
    "test:contact": "playwright test tests/05-contact-form.spec.js",
    "test:wpml": "playwright test tests/06-wpml-en.spec.js",
    "test:local-links": "playwright test tests/07-local-links.spec.js",
    "test:headed": "playwright test --headed",
    "report": "playwright show-report",
    "test:report": "playwright test --reporter=json,list; node generate-report.js"
  },
  "devDependencies": {
    "@playwright/test": "^1.52.0",
    "dotenv": "^17.0.0"
  }
}
