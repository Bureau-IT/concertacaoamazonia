{
  "_meta": {
    "name": "wp-static-paths",
    "version": "1.0.0",
    "description": "Scope-down statement reutilizavel: matches request que NAO esta em path estatico WordPress (wp-content, wp-includes, favicon.ico, robots.txt). Usar como AndStatement child de RateBased rules para evitar contar sub-requests CSS/JS/imagens (80-150 por page load).",
    "source_incident": "feedback_waf_ratelimit_static_paths",
    "wcu_estimate": 6,
    "usage": "Inline esse statement dentro de AndStatement.Statements[] junto com seu match principal. SearchString fields ja base64-encoded para uso direto em update-web-acl --cli-input-json."
  },
