erenças e propor fix.","activeForm":"Comparando dev vs green pagina por pagina","status":"completed","blocks":[],"blockedBy":[]},{"id":"50","subject":"Limpar S3 green de Elementor CSS vazado","description":"aws s3 rm dos post-XX.css em green/uploads/elementor/ e green/uploads/sites/2/elementor/ para garantir comportamento determinístico","activeForm":"Limpando S3 green de Elementor CSS vazado","status":"completed","blocks":[],"blockedBy":[]},{"id":"51","subject":"Mu-plugin v2.0.0 com pre-warmup do static cache","description":"Reescrever bit-elementor-local-cache.php para pre-aquecer Base::$wp_uploads_dir com path local antes do S3-Uploads","activeForm":"Reescrevendo bit-elementor-local-cache v2.0.0","status":"completed","blocks":[],"blockedBy":[]},{"id":"52","subject":"Deploy mu-plugin v2 na green + flush + regenerar","description":"Rsync mu-plugin novo para green, apagar elementor-cache antigo, wp elementor flush_css, validar URLs no HTML","activeForm":"Deployando mu-plugin v2 na green","status":"completed","blocks":[],"blockedBy":[]},{"id":"53","subject":"CF behaviors */elementor/css/* → ALB (defesa em profundidade)","description":"Adicionar 4 behaviors CloudFront para capturar URLs legadas de elementor CSS em filesystem path → ALB","activeForm":"Adicionando CF behaviors elementor/css → ALB","status":"completed","blocks":[],"blockedBy":[]},{"id":"54","subject":"Fix CF cache pollution + keepalive","description":"Auditoria 10 agentes — aplicar 3 fixes CF + Playwright + invalidate","activeForm":"Aplicando fixes CF","status":"completed","blocks":[],"blockedBy":[]}],"itemCount":32},"type":"attachment","uuid":"a442155c-4f70-46f7-92dc-2b8b46f9724d","timestamp":"2026-05-02T02:43:23.943Z","userType":"external","entrypoint":"cli","cwd":"/Users/dcambria/scripts/server-tools/v2/docker-dev/sites/concertacao","sessionId":"55811d4e-34d6-42df-9582-284664a6a576","version":"2.1.126","gitBranch":"main","slug":"prepare-o-deploy-do-snappy-taco"}
