ia.com.br/?cb=1777689272425\n- Page Title: Uma Concertação pela Amazonia – Conexão de saberes, pessoas e instituições engajadas no desenvolvimento sustentável da Amazônia.\n- Console: 0 errors, 2 warnings\n### Events\n- New console entries: ../tmp/playwright-output/console-2026-05-02T02-34-22-087Z.log#L1-L2\n- [LOG] JQMIGRATE: Migrate is installed, version 3.4...-includes/js/jquery/jquery-migrate.min.js?ver=3.4.1:1\n- [LOG] TrafficSourceCookie initialized @ https://d3...ipts/6e654cf7-3d68-42ea-856e-6946c35998d3-loader.js:0\n- [LOG] [RDTracker] initialized @ https://d335luupug...ipts/6e654cf7-3d68-42ea-856e-6946c35998d3-loader.js:0\n- [LOG] FormIntegration; ver.2.0.0 initialized @ htt...ipts/6e654cf7-3d68-42ea-856e-6946c35998d3-loader.js:0\n- [WARNING] The resource https://concertacaoamazonia...ttps://concertacaoamazonia.com.br/?cb=1777689262097:0\n- [LOG] JQMIGRATE: Migrate is installed, version 3.4...-includes/js/jquery/jquery-migrate.min.js?ver=3.4.1:1\n- [LOG] TrafficSourceCookie initialized @ https://d3...ipts/6e654cf7-3d68-42ea-856e-6946c35998d3-loader.js:0\n- [LOG] FormIntegration; ver.2.0.0 initialized @ htt...ipts/6e654cf7-3d68-42ea-856e-6946c35998d3-loader.js:0\n- [LOG] [RDTracker] initialized @ https://d335luupug...ipts/6e654cf7-3d68-42ea-856e-6946c35998d3-loader.js:0\n- [WARNING] The resource https://concertacaoamazonia...ttps://concertacaoamazonia.com.br/?cb=1777689272425:0"}]}]},"uuid":"969993e7-86b9-4953-9c15-b67de5560bce","timestamp":"2026-05-02T02:34:42.907Z","toolUseResult":[{"type":"text","text":"### Result\n{\"initial\":{\"banner_visible\":false,\"banner_text\":null,\"has_accept\":false,\"accept_label\":null,\"has_deny\":false,\"deny_label\":null,\"window_complianz\":false,\"window_cmplz\":false,\"cmplz_html_count\":0},\"afterAccept\":{\"cmplz_cookies_count\":0,\"cmplz_cookies_sample\":[],\"gtm_loaded\":true,\"ga_loaded\":true,\"youtube_loaded\":false,\"rd_loaded\":true},\"afterDeny\":{\"gtm_present\":true,\"ga_present\":true,\"youtube_present\":false}}\n### Ran Playwright code\n```js\nawait (async (page) => {\n  // ==== AUDITORIA Complianz pós-configuração ====\n  await page.context().clearCookies();\n  await page.goto('https://concertacaoamazonia.com.br/?cb=' + Date.now(), { waitUntil: 'networkidle', timeout: 30000 });\n  await page.waitForTimeout(4000); // tempo extra pro Complianz inicializar\n\n  const initial = await page.evaluate(() => {\n    const banner = document.querySelector('.cmplz-cookiebanner, #cmplz-cookiebanner-container, [class*=\"cmplz-banner\"]');\n    const acceptBtn = document.querySelector('.cmplz-accept, button.cmplz-accept-all, [data-cmplz-action=\"accept\"]');\n    const denyBtn = document.querySelector('.cmplz-deny, button.cmplz-deny-all, [data-cmplz-action=\"deny\"]');\n    return {\n      banner_visible: banner ? getComputedStyle(banner).display !== 'none' : false,\n      banner_text: banner?.innerText?.slice(0, 200) || null,\n      has_accept: !!acceptBtn,\n      accept_label: acceptBtn?.innerText?.trim() || null,\n      has_deny: !!denyBtn,\n      deny_label: denyBtn?.innerText?.trim() || null,\n      window_complianz: typeof window.complianz !== 'undefined',\n      window_cmplz: typeof window.cmplz !== 'undefined',\n      cmplz_html_count: (document.body.innerHTML.match(/cmplz/gi) || []).length,\n    };\n  });\n\n  // Aceitar\n  await page.evaluate(() => {\n    const btn = document.querySelector('.cmplz-accept, button.cmplz-accept-all, [data-cmplz-action=\"accept\"]');\n    if (btn) btn.click();\n  });\n  await page.waitForTimeout(3000);\n\n  const afterAccept = await page.evaluate(() => {\n    const cookies = document.cookie.split(';').map(c => c.trim());\n    const cmplzCookies = cookies.filter(c => c.startsWith('cmplz_'));\n    const scripts = Array.from(document.querySelectorAll('script[src]')).map(s => s.src);\n    return {\n      cmplz_cookies_count: cmplzCookies.length,\n      cmplz_cookies_sample: cmplzCookies.slice(0, 6).map(c => c.split('=')[0]),\n      gtm_loaded: scripts.some(s => /googletagmanager|gtag/.test(s)),\n      ga_loaded: scripts.some(s => /google-analytics|stats\\.g\\.doubleclick/.test(s)),\n      youtube_loaded: scripts.some(s => /youtube\\.com\\/iframe_api/.test(s)),\n      rd_loaded: scripts.some(s => /d335luupugsy2|rdstation/.test(s)),\n    };\n  });\n\n  // Reset + Negar\n  await page.context().clearCookies();\n  await page.goto('https://concertacaoamazonia.com.br/?cb=' + Date.now(), { waitUntil: 'networkidle', timeout: 30000 });\n  await page.waitForTimeout(4000);\n  await page.evaluate(() => {\n    const btn = document.querySelector('.cmplz-deny, button.cmplz-deny-all, [data-cmplz-action=\"deny\"]');\n    if (btn) btn.click();\n  });\n  await page.waitForTimeout(3000);\n\n  const afterDeny = await page.evaluate(() => {\n    const scripts = Array.from(document.querySelectorAll('script[src]')).map(s => s.src);\n    return {\n      gtm_present: scripts.some(s => /googletagmanager|gtag/.test(s)),\n      ga_present: scripts.some(s => /google-analytics|stats\\.g\\.doubleclick/.test(s)),\n      youtube_present: scripts.some(s => /youtube\\.com\\/iframe_api/.test(s)),\n    };\n  });\n\n  return { initial, afterAccept, afterDeny };\n})(page);\n```\n### Page\n- Page URL: https://concertacaoamazonia.com.br/?cb=1777689272425\n- Page Title: Uma Concertação pela Amazonia – Conexão de saberes, pessoas e instituições engajadas no desenvolvimento sustentável da Amazônia.\n- Console: 0 errors, 2 warnings\n### Events\n- New console entries: ../tmp/playwright-output/console-2026-05-02T02-34-22-087Z.log#L1-L2\n- [LOG] JQMIGRATE: Migrate is installed, version 3.4...-includes/js/jquery/jquery-migrate.min.js?ver=3.4.1:1\n- [LOG] TrafficSourceCookie initialized @ https://d3...ipts/6e654cf7-3d68-42ea-856e-6946c35998d3-loader.js:0\n- [LOG] [RDTracker] initialized @ https://d335luupug...ipts/6e654cf7-3d68-42ea-856e-6946c35998d3-loader.js:0\n- [LOG] FormIntegration; ver.2.0.0 initialized @ htt...ipts/6e654cf7-3d68-42ea-856e-6946c35998d3