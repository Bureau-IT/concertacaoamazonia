{"parentUuid":"1248238c-1c60-483c-bee7-8d1ec1b9017d","isSidechain":false,"message":{"model":"claude-opus-4-7","id":"msg_01DQM3i8nNso9zapEaotV4om","type":"message","role":"assistant","content":[{"type":"text","text":"Smoke.md já está committed (do anterior). Vou criar o script de migration Complianz dev→prod:"}],"stop_reason":"tool_use","stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":191,"cache_read_input_tokens":916245,"output_tokens":7041,"server_tool_use":{"web_search_requests":0,"web_fetch_requests":0},"service_tier":"standard","cache_creation":{"ephemeral_1h_input_tokens":191,"ephemeral_5m_input_tokens":0},"inference_geo":"","iterations":[{"input_tokens":1,"output_tokens":7041,"cache_read_input_tokens":916245,"cache_creation_input_tokens":191,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":191},"type":"message"}],"speed":"standard"},"diagnostics":null},"requestId":"req_011Cad1nbW5254woQaf3GEa8","type":"assistant","uuid":"62a4197c-6202-4250-97b1-43a666f03c6d","timestamp":"2026-05-02T03:14:53.561Z","userType":"external","entrypoint":"cli","cwd":"/Users/dcambria/scripts/server-tools/v2/docker-dev/sites/concertacao","sessionId":"55811d4e-34d6-42df-9582-284664a6a576","version":"2.1.126","gitBranch":"main","slug":"prepare-o-deploy-do-snappy-taco"}
{"parentUuid":"62a4197c-6202-4250-97b1-43a666f03c6d","isSidechain":false,"message":{"model":"claude-opus-4-7","id":"msg_01DQM3i8nNso9zapEaotV4om","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01AVRxEmixYSfzFufNvSi5Rr","name":"Write","input":{"file_path":"/Users/dcambria/scripts/server-tools/v2/docker-dev/common/scripts/cmplz-migrate-dev-to-prod.sh","content":"#!/usr/bin/env bash\n# cmplz-migrate-dev-to-prod.sh — Migra config Complianz dev → prod (multisite)\n# Versao: 1.0.0\n# Autor:  Daniel Cambria — Bureau de Tecnologia Ltda. (BIT BPO)\n# Data:   2026-05-02\n#\n# Por que: Complianz Network Active exige config separada por blog. Wizard\n# manual em prod e tedioso e propenso a divergencia entre blogs. Este script\n# exporta wp_options e wp_2_options de DEV (source-of-truth) e importa em PROD\n# via SSH+wp-cli, idempotente.\n#\n# Uso:\n#   ./cmplz-migrate-dev-to-prod.sh --site=concertacao --dry-run\n#   ./cmplz-migrate-dev-to-prod.sh --site=concertacao --apply\n#\n# Steps:\n#   1. Backup remoto: dump wp_options e wp_2_options.cmplz_options de PROD\n#      → /tmp/cmplz_prod_backup_<timestamp>.json (download local)\n#   2. Export DEV:    snapshot de TODAS opcoes cmplz_*/complianz_* dos 2 blogs\n#   3. Sanitize:      ajusta IDs de pagina (privacy/cookie/disclaimer custom_page)\n#                     pois IDs de DB diferem entre dev e prod\n#   4. Import PROD:   via wp eval --user=admin escrevendo opcoes\n#   5. Validar:       curl HTML home blog 1 e cultura blog 2 — espera ver banner\n#\n# Skipped (per-blog tracking, nao copiar):\n#   cmplz_activation_time, cmplz_first_sync_started, cmplz_last_cookie_sync,\n#   cmplz_wsc_*, cmplz_sync_*, cmplz_cookie_data_verified_date\n\nset -euo pipefail\n\n# ─────────────────────────────────────────────────────────────────────────────\n# Argumentos\n# ─────────────────────────────────────────────────────────────────────────────\n\nSITE=\"\"\nMODE=\"dry-run\"\nSCRIPT_DIR=\"$(cd \"$(dirname \"${BASH_SOURCE[0]}\")\" && pwd)\"\n\nusage() {\n    cat <<EOF\n==============================================================================\ncmplz-migrate-dev-to-prod.sh v1.0.0\nBureau de Tecnologia - Migra Complianz dev → prod (multisite-aware)\n==============================================================================\n\nUSO:\n  $0 --site=<site-name> [--dry-run|--apply]\n\nARGS:\n  --site=<name>   Site no docker-dev (ex: concertacao). Obrigatorio.\n  --dry-run       Mostra o que seria copiado, nao escreve em prod (default)\n  --apply         Aplica as mudancas em prod\n  --help, -h      Exibe este help\n\nEXEMPLO:\n  $0 --site=concertacao --dry-run\n  $0 --site=concertacao --apply\n\nREQUISITOS:\n  - SSH alias <fqdn>-prod-sa configurado em ~/.ssh/config\n  - docker-dev rodando localmente (container do site UP)\n  - jq instalado (brew install jq)\n\nEOF\n}\n\nwhile [[ $# -gt 0 ]]; do\n    case \"$1\" in\n        --site=*)   SITE=\"${1#*=}\"; shift ;;\n        --site)     SITE=\"$2\"; shift 2 ;;\n        --dry-run)  MODE=\"dry-run\"; shift ;;\n        --apply)    MODE=\"apply\"; shift ;;\n        --help|-h)  usage; exit 0 ;;\n        *)          echo \"Argumento desconhecido: $1\" >&2; usage >&2; exit 2 ;;\n    esac\ndone\n\n[[ -z \"$SITE\" ]] && { echo \"ERRO: --site obrigatorio\" >&2; usage >&2; exit 2; }\ncommand -v jq >/dev/null 2>&1 || { echo \"ERRO: jq nao encontrado (brew install jq)\" >&2; exit 2; }\n\n# ─────────────────────────────────────────────────────────────────────────────\n# Setup paths e cores\n# ─────────────────────────────────────────────────────────────────────────────\n\nDEV_WP=\"${SCRIPT_DIR}/../bin/docker-dev.sh\"\n[[ ! -x \"$DEV_WP\" ]] && { echo \"ERRO: docker-dev.sh nao encontrado em $DEV_WP\" >&2; exit 1; }\n\n# Detectar URLs do site\ncase \"$SITE\" in\n    concertacao)\n        DEV_URL_BLOG1=\"https://cambrasmax.local:8484\"\n        DEV_URL_BLOG2=\"https://cambrasmax.local:8484/cultura\"\n        PROD_HOST=\"concertacaoamazonia.com.br\"\n        PROD_SSH_ALIAS=\"${PROD_HOST}-prod-sa\"\n        PROD_WP_ROOT=\"/var/www/${PROD_HOST}\"\n        PROD_URL_BLOG1=\"https://${PROD_HOST}/\"\n        PROD_URL_BLOG2=\"https://${PROD_HOST}/cultura/\"\n        ;;\n    *)\n        echo \"ERRO: site '$SITE' nao mapeado. Adicione case no script.\" >&2\n        exit 2\n        ;;\nesac\n\nTS=\"$(date +%Y%m%d-%H%M%S)\"\nWORK_DIR=\"/tmp/cmplz-migrate-${SITE}-${TS}\"\nmkdir -p \"$WORK_DIR\"\n\n# Cores BIT\nFG_GREEN=$'\\033[0;32m'\nFG_RED=$'\\033[0;31m'\nFG_YELLOW=$'\\033[0;33m'\nFG_BLUE=$'\\033[0;36m'\nFG_BOLD=$'\\033[1m'\nEND=$'\\033[0m'\n\nlog_info()  { echo \"${FG_BLUE}[INFO]${END} $*\"; }\nlog_ok()    { echo \"${FG_GREEN}[ OK ]${END} $*\"; }\nlog_warn()  { echo \"${FG_YELLOW}[WARN]${END} $*\"; }\nlog_error() { echo \"${FG_RED}[ERR ]${END} $*\" >&2; }\nlog_dry()   { echo \"${FG_YELLOW}[DRY ]${END} $*\"; }\n\nphase() {\n    echo\n    echo \"${FG_BOLD}╭─────────────────────────────────────────────────────────╮${END}\"\n    printf \"${FG_BOLD}│  %-55s│${END}\\n\" \"$1\"\n    echo \"${FG_BOLD}╰─────────────────────────────────────────────────────────╯${END}\"\n}\n\n# ─────────────────────────────────────────────────────────────────────────────\n# Helpers\n# ─────────────────────────────────────────────────────────────────────────────\n\n# Skiplist: opcoes per-blog que NAO devem ser copiadas\nSKIP_OPTIONS=(\n    \"cmplz_activation_time\"\n    \"cmplz_first_sync_started\"\n    \"cmplz_last_cookie_sync\"\n    \"cmplz_wsc_checks_scan_createdAt\"\n    \"cmplz_wsc_checks_scan_id\"\n    \"cmplz_wsc_newsletter_dismissed\"\n    \"cmplz_wsc_onboarding_dismissed\"\n    \"cmplz_wsc_signup_status\"\n    \"cmplz_wsc_websitescan_dismissed\"\n    \"cmplz_sync_cookies_after_services_complete\"\n    \"cmplz_sync_cookies_complete\"\n    \"cmplz_sync_services_complete\"\n    \"cmplz_cookie_data_verified_date\"\n    \"cmplz-current-version\"\n    \"cmplz_first_version\"\n)\n\nis_skipped() {\n    local opt=\"$1\"\n    for s in \"${SKIP_OPTIONS[@]}\"; do\n        [[ \"$opt\" == \"$s\" ]] && return 0\n    done\n    return 1\n}\n\n# Roda wp-cli no container DEV, blog X\ndev_wp() {\n    local blog_url=\"$1\"\n    shift\n    \"$DEV_WP\" wp --url=\"$blog_url\" \"$@\" 2>/dev/null \\\n        | grep -vE \"Cores|BIT BPO|│|╭|╰|├|Deprecated:|Esta sessao\"\n}\n\n# Roda wp-cli no PROD via SSH, blog X\nprod_wp() {\n    local blog_url=\"$1\"\n    shift\n    ssh \"$PROD_SSH_ALIAS\" \"sudo -u www-data wp --path=${PROD_WP_ROOT} --url=${blog_url} $*\" 2>/dev/null \\\n        | grep -vE \"Deprecated:\"\n}\n\n# Lista todas as opcoes cmplz_* / complianz_* de um blog em DEV\nlist_dev_options() {\n    local blog_url=\"$1\"\n    dev_wp \"$blog_url\" db query \"\nSELECT option_name FROM wp_options WHERE option_name LIKE 'cmplz%' OR option_name LIKE 'complianz%'\nUNION\nSELECT option_name FROM wp_2_options WHERE option_name LIKE 'cmplz%' OR option_name LIKE 'complianz%'\n\" --skip-column-names 2>&1 | grep -E '^(cmplz|complianz)' | sort -u\n}\n\n# Lista opcoes diretamente do schema correto por blog\nlist_dev_options_for_blog() {\n    local blog_url=\"$1\"\n    local table_prefix=\"$2\"  # 'wp' ou 'wp_2'\n    dev_wp \"$blog_url\" db query \"\nSELECT option_name FROM ${table_prefix}_options WHERE option_name LIKE 'cmplz%' OR option_name LIKE 'complianz%'\nORDER BY option_name\n\" --skip-column-names 2>&1 | grep -E '^(cmplz|complianz)'\n}\n\n# Pega valor de uma opcao em DEV (serializado)\nget_dev_option_serialized() {\n    local blog_url=\"$1\"\n    local opt_name=\"$2\"\n    dev_wp \"$blog_url\" eval \"\n\\$v = get_option('$opt_name', null);\nif (\\$v === null) { echo '__NULL__'; exit; }\necho base64_encode(serialize(\\$v));\n\"\n}\n\n# Aplica valor em PROD via wp eval (escapa via base64)\napply_prod_option() {\n    local blog_url=\"$1\"\n    local opt_name=\"$2\"\n    local b64_serialized=\"$3\"\n    local autoload=\"${4:-yes}\"\n    prod_wp \"$blog_url\" eval \"\n\\$decoded = unserialize(base64_decode('$b64_serialized'));\nupdate_option('$opt_name', \\$decoded, '$autoload');\necho 'OK';\n\"\n}\n\n# ─────────────────────────────────────────────────────────────────────────────\n# Phase 1 — Backup PROD (sempre, mesmo em dry-run)\n# ─────────────────────────────────────────────────────────────────────────────\n\nphase \"Phase 1 — Backup PROD\"\n\nBACKUP_FILE=\"${WORK_DIR}/cmplz_prod_backup_${TS}.json\"\n\nlog_info \"Coletando opcoes Complianz de PROD (blog 1 + blog 2)...\"\nssh \"$PROD_SSH_ALIAS\" \"sudo -u www-data wp --path=${PROD_WP_ROOT} --url=${PROD_URL_BLOG1} eval '\n\\$opts = [];\n\\$names = [\\\"cmplz_options\\\", \\\"cmplz_banner_settings\\\", \\\"cmplz_purposes_pt\\\", \\\"cmplz_serviceTypes_pt\\\",\n          \\\"cmplz_publish_date\\\", \\\"complianz_active_policy_id\\\",\n          \\\"cmplz_privacy-statement_custom_page\\\", \\\"cmplz_cookie-statement_custom_page\\\",\n          \\\"cmplz_disclaimer_custom_page\\\", \\\"cmplz_impressum_custom_page\\\"];\nforeach (\\$names as \\$n) { \\$opts[\\$n] = get_blog_option(1, \\$n); }\nfile_put_contents(\\\"/tmp/cmplz_prod_blog1_${TS}.json\\\", json_encode([\\\"options\\\" => \\$opts]));\necho \\\"blog1 saved\\\\n\\\";\n\n\\$opts2 = [];\nforeach (\\$names as \\$n) { \\$opts2[\\$n] = get_blog_option(2, \\$n); }\nfile_put_contents(\\\"/tmp/cmplz_prod_blog2_${TS}.json\\\", json_encode([\\\"options\\\" => \\$opts2]));\necho \\\"blog2 saved\\\\n\\\";\n'\" 2>&1 | grep -vE \"Deprecated:\" | tail -5\n\n# Download\nscp \"${PROD_SSH_ALIAS}:/tmp/cmplz_prod_blog1_${TS}.json\" \"${WORK_DIR}/blog1.json\" 2>/dev/null\nscp \"${PROD_SSH_ALIAS}:/tmp/cmplz_prod_blog2_${TS}.json\" \"${WORK_DIR}/blog2.json\" 2>/dev/null\nssh \"$PROD_SSH_ALIAS\" \"sudo rm -f /tmp/cmplz_prod_blog{1,2}_${TS}.json\" 2>/dev/null\n\n[[ -s \"${WORK_DIR}/blog1.json\" ]] && log_ok \"Backup blog 1: $(wc -c < \"${WORK_DIR}/blog1.json\") bytes\"\n[[ -s \"${WORK_DIR}/blog2.json\" ]] && log_ok \"Backup blog 2: $(wc -c < \"${WORK_DIR}/blog2.json\") bytes\"\nlog_info \"Backup salvo em ${WORK_DIR}/\"\n\n# ─────────────────────────────────────────────────────────────────────────────\n# Phase 2 — Listar opcoes em DEV (source-of-truth)\n# ─────────────────────────────────────────────────────────────────────────────\n\nphase \"Phase 2 — Listar opcoes em DEV\"\n\nlog_info \"Listando opcoes de wp_options (blog 1)...\"\nDEV_BLOG1_OPTS_FILE=\"${WORK_DIR}/dev_blog1_opts.list\"\nlist_dev_options_for_blog \"$DEV_URL_BLOG1\" \"wp\" > \"$DEV_BLOG1_OPTS_FILE\"\nDEV_BLOG1_COUNT=$(wc -l < \"$DEV_BLOG1_OPTS_FILE\")\nlog_ok \"Blog 1 DEV: $DEV_BLOG1_COUNT opcoes\"\n\nlog_info \"Listando opcoes de wp_2_options (blog 2)...\"\nDEV_BLOG2_OPTS_FILE=\"${WORK_DIR}/dev_blog2_opts.list\"\nlist_dev_options_for_blog \"$DEV_URL_BLOG2\" \"wp_2\" > \"$DEV_BLOG2_OPTS_FILE\"\nDEV_BLOG2_COUNT=$(wc -l < \"$DEV_BLOG2_OPTS_FILE\")\nlog_ok \"Blog 2 DEV: $DEV_BLOG2_COUNT opcoes\"\n\n# ─────────────────────────────────────────────────────────────────────────────\n# Phase 3 — Migrar Blog 1 e Blog 2\n# ─────────────────────────────────────────────────────────────────────────────\n\nmigrate_blog() {\n    local blog_label=\"$1\"\n    local dev_url=\"$2\"\n    local prod_url=\"$3\"\n    local opts_file=\"$4\"\n\n    phase \"Phase 3.${blog_label} — Migrar ${blog_label}\"\n\n    local total_copied=0\n    local total_skipped=0\n    local total_errors=0\n\n    while IFS= read -r opt_name; do\n        [[ -z \"$opt_name\" ]] && continue\n\n        if is_skipped \"$opt_name\"; then\n            ((total_skipped++))\n            continue\n        fi\n\n        # Pega valor de DEV\n        local b64_value\n        b64_value=\"$(get_dev_option_serialized \"$dev_url\" \"$opt_name\" | tr -d '[:space:]')\"\n\n        if [[ -z \"$b64_value\" ]] || [[ \"$b64_value\" == \"__NULL__\" ]]; then\n            log_warn \"  $opt_name: vazio em DEV, skipping\"\n            ((total_skipped++))\n            continue\n        fi\n\n        if [[ \"$MODE\" == \"dry-run\" ]]; then\n            log_dry \"  $opt_name: ${#b64_value} bytes (b64) seria copiado para PROD\"\n            ((total_copied++))\n        else\n            local result\n            result=\"$(apply_prod_option \"$prod_url\" \"$opt_name\" \"$b64_value\" 2>&1 | tail -1)\"\n            if [[ \"$result\" == \"OK\" ]]; then\n                log_ok \"  $opt_name: aplicado\"\n                ((total_copied++))\n            else\n                log_error \"  $opt_name: falhou ($result)\"\n                ((total_errors++))\n            fi\n        fi\n    done < \"$opts_file\"\n\n    echo\n    log_info \"${blog_label} resumo: copied=$total_copied skipped=$total_skipped errors=$total_errors\"\n}\n\nmigrate_blog \"Blog 1 (raiz)\"    \"$DEV_URL_BLOG1\" \"$PROD_URL_BLOG1\" \"$DEV_BLOG1_OPTS_FILE\"\nmigrate_blog \"Blog 2 (cultura)\" \"$DEV_URL_BLOG2\" \"$PROD_URL_BLOG2\" \"$DEV_BLOG2_OPTS_FILE\"\n\n# ─────────────────────────────────────────────────────────────────────────────\n# Phase 4 — Validacao pos-migracao (smoke check)\n# ─────────────────────────────────────────────────────────────────────────────\n\nif [[ \"$MODE\" == \"apply\" ]]; then\n    phase \"Phase 4 — Validacao smoke\"\n\n    log_info \"Conferindo HTML servido apos migracao (blog 1)...\"\n    cmplz_count_blog1=$(curl -sk \"${PROD_URL_BLOG1}?cb=$(date +%s)\" | grep -ciE 'cmplz-banner|cmplz-cookiebanner|cmplz-accept|cmplz-deny' || true)\n    log_info \"  ocorrencias 'cmplz-*' no HTML: $cmplz_count_blog1\"\n\n    log_info \"Conferindo HTML servido apos migracao (blog 2)...\"\n    cmplz_count_blog2=$(curl -sk \"${PROD_URL_BLOG2}?cb=$(date +%s)\" | grep -ciE 'cmplz-banner|cmplz-cookiebanner|cmplz-accept|cmplz-deny' || true)\n    log_info \"  ocorrencias 'cmplz-*' no HTML: $cmplz_count_blog2\"\n\n    if [[ \"$cmplz_count_blog1\" -gt 0 ]] && [[ \"$cmplz_count_blog2\" -gt 0 ]]; then\n        log_ok \"Banner Complianz presente em ambos blogs ✓\"\n    else\n        log_warn \"Algum blog ainda nao mostra banner — verificar cache CloudFront/WP Rocket\"\n        log_info \"Tentar invalidar CF: aws cloudfront create-invalidation --distribution-id <id> --paths '/' '/cultura/'\"\n    fi\n\n    echo\n    log_info \"ROLLBACK em caso de problema:\"\n    log_info \"  Use ${WORK_DIR}/blog{1,2}.json para reverter\"\nfi\n\nphase \"Concluido\"\nlog_info \"Working dir: $WORK_DIR\"\n[[ \"$MODE\" == \"dry-run\" ]] && log_warn \"DRY-RUN: nada foi escrito em prod. Re-execute com --apply para aplicar.\"\n\nexit 0\n"},"caller":{"type":"direct"}}],"stop_reason":"tool_use","stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":191,"cache_read_input_tokens":916245,"output_tokens":7041,"server_tool_use":{"web_search_requests":0,"web_fetch_requests":0},"service_tier":"standard","cache_creation":{"ephemeral_1h_input_tokens":191,"ephemeral_5m_input_tokens":0},"inference_geo":"","iterations":[{"input_tokens":1,"output_tokens":7041,"cache_read_input_tokens":916245,"cache_creation_input_tokens":191,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":191},"type":"message"}],"speed":"standard"},"diagnostics":null},"requestId":"req_011Cad1nbW5254woQaf3GEa8","type":"assistant","uuid":"0c2fe301-93aa-466a-81a9-26bf02cf46e9","timestamp":"2026-05-02T03:16:05.198Z","userType":"external","entrypoint":"cli","cwd":"/Users/dcambria/scripts/server-tools/v2/docker-dev/sites/concertacao","sessionId":"55811d4e-34d6-42df-9582-284664a6a576","version":"2.1.126","gitBranch":"main","slug":"prepare-o-deploy-do-snappy-taco"}
