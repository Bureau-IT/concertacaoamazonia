complianz/i.test(s.src)).length,\n        window_complianz: typeof window.complianz !== 'undefined',\n        // Verificar se Consent Mode v2 (Google Ads) está ativo\n        gtag_consent_default: typeof window.gtag !== 'undefined' || (Array.isArray(window.dataLayer) && window.dataLayer.some(e => e[0] === 'consent')),\n        datalayer_consent_events: Array.isArray(window.dataLayer)\n          ? window.dataLayer.filter(e => Array.isArray(e) && e[0] === 'consent').map(e => ({mode: e[1], values: e[2]}))\n          : [],\n      };\n    });\n  };\n  return {\n    blog1: await audit('https://concertacao.bureau-it.com/'),\n    blog2: await audit('https://concertacao.bureau-it.com/cultura/'),\n  };\n})(page);\n```\n### Page\n- Page URL: https://concertacao.bureau-it.com/cultura/?cb=1777690306767\n- Page Title: Uma Concertação pela Amazonia: Cultura – Conexão de saberes, pessoas e instituições engajadas no desenvolvimento sustentável da Amazônia.\n- Console: 0 errors, 3 warnings\n### Events\n- New console entries: ../tmp/playwright-output/console-2026-05-02T02-51-38-245Z.log#L1-L3\n- [LOG] JQMIGRATE: Migrate is installed with logging...wp-includes/js/jquery/jquery-migrate.js?ver=3.4.1:103\n- [LOG] opt-in @ https://concertacao.bureau-it.com/w...gdpr/cookiebanner/js/complianz.js?ver=1774279960:1102\n- [WARNING] JQMIGRATE: jQuery.type is deprecated @ h...wp-includes/js/jquery/jquery-migrate.js?ver=3.4.1:135\n- [WARNING] The resource https://concertacao.bureau-...https://concertacao.bureau-it.com/?cb=1777690298255:0\n- [LOG] JQMIGRATE: Migrate is installed with logging...wp-includes/js/jquery/jquery-migrate.js?ver=3.4.1:103\n- [WARNING] The resource https://concertacao.bureau-...concertacao.bureau-it.com/cultura/?cb=1777690306767:0"}]}]},"uuid":"3f4fabc5-0489-4f7d-b767-6eed0d6832d5","timestamp":"2026-05-02T02:51:53.699Z","toolUseResult":[{"type":"text","text":"### Result\n{\"blog1\":{\"banner_visible\":true,\"banner_text\":\"Gerenciar consentimento\\nPara proporcionar uma melh