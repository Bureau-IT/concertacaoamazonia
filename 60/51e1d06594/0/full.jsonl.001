onst resp = await page.goto(url + '?cb=measure' + Date.now(), { waitUntil: 'domcontentloaded', timeout: 25000 });\n      const ttfb = Date.now() - t0;\n      const headers = resp ? resp.headers() : {};\n      results.push({\n        url: url.replace('https://concertacaoamazonia.com.br', ''),\n        status: resp ? resp.status() : 0,\n        ttfb_ms: ttfb,\n        x_cache: headers['x-cache'] || null,\n        age: headers['age'] || null,\n        x_rocket_reason: headers['x-rocket-reason'] || null,\n      });\n    } catch (e) {\n      results.push({\n        url: url.replace('https://concertacaoamazonia.com.br', ''),\n        error: (e.message || '?').slice(0, 80),\n      });\n    }\n  }\n  return { menu_count: menuUrls.length, items: results };\n})(page);\n```\n### Page\n- Page URL: https://concertacaoamazonia.com.br/conhecimento/entrevistas/?cb=measure1777686981596\n- Page Title: Entrevistas – Uma Concertação pela Amazonia\n- Console: 1 errors, 0 warnings\n### Events\n- New console entries: ../tmp/playwright-output/console-2026-05-02T01-55-49-867Z.log#L1\n- [LOG] JQMIGRATE: Migrate is installed, version 3.4...-includes/js/jquery/jquery-migrate.min.js?ver=3.4.1:1\n- [LOG] JQMIGRATE: Migrate is installed, version 3.4...-includes/js/jquery/jquery-migrate.min.js?ver=3.4.1:1\n- [LOG] JQMIGRATE: Migrate is installed, version 3.4...-includes/js/jquery/jquery-migrate.min.js?ver=3.4.1:1\n- [LOG] TrafficSourceCookie initialized @ https://d3...ipts/6e654cf7-3d68-42ea-856e-6946c35998d3-loader.js:0\n- [LOG] [RDTracker] initialized @ https://d335luupug...ipts/6e654cf7-3d68-42ea-856e-6946c35998d3-loader.js:0\n- [LOG] FormIntegration; ver.2.0.0 initialized @ htt...ipts/6e654cf7-3d68-42ea-856e-6946c35998d3-loader.js:0\n- [LOG] JQMIGRATE: Migrate is installed, version 3.4...-includes/js/jquery/jquery-migrate.min.js?ver=3.4.1:1\n- [LOG] TrafficSourceCookie initialized @ https://d3...ipts/6e654cf7-3d68-42ea-856e-6946c35998d3-loader.js:0\n- [LOG] JQMIGRATE: Migrate is installed, ver