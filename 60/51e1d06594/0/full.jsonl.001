 data = await page.evaluate(async () => {\n        let hostname = 'unknown';\n        try {\n          const r = await fetch('/check-ec2.php?cb=' + Date.now(), { cache: 'no-store' });\n          hostname = ((await r.text()).match(/Hostname:\\s*([^\\n<]+)/) || [])[1]?.trim() || 'unknown';\n        } catch(e){}\n        const jsf = window.JetSmartFilterSettings?.props || {};\n        let max_found = 0;\n        for (const provider in jsf) for (const qid in jsf[provider]) {\n          const v = jsf[provider][qid].found_posts || 0;\n          if (v > max_found) max_found = v;\n        }\n        return {\n          hostname,\n          jet_max_found_posts: max_found,\n          listing_items: document.querySelectorAll('.jet-listing-grid__item').length,\n          uploads_elementor_css: Array.from(document.querySelectorAll('link[rel=\"stylesheet\"]')).filter(l => /\\/uploads\\/(?:sites\\/\\d+\\/)?elementor\\//.test(l.href)).length,\n        };\n      });\n      results[key] = { ...data, elementor_cache_404s: cache404s.length };\n    } catch (e) {\n      results[key] = { error: (e.message || '?').slice(0, 80) };\n    }\n  }\n  return results;\n})(page);\n```\n### Page\n- Page URL: https://concertacaoamazonia.com.br/conhecimento/espiral-de-conhecimento/?cb=1777688083281\n- Page Title: Espiral de Conhecimento – Uma Concertação pela Amazonia\n- Console: 0 errors, 1 warnings\n### Events\n- New console entries: ../tmp/playwright-output/console-2026-05-02T02-14-23-299Z.log#L1\n- [LOG] JQMIGRATE: Migrate is installed, version 3.4...-includes/js/jquery/jquery-migrate.min.js?ver=3.4.1:1\n- [LOG] TrafficSourceCookie initialized @ https://d3...ipts/6e654cf7-3d68-42ea-856e-6946c35998d3-loader.js:0\n- [LOG] [RDTracker] initialized @ https://d335luupug...ipts/6e654cf7-3d68-42ea-856e-6946c35998d3-loader.js:0\n- [LOG] FormIntegration; ver.2.0.0 initialized @ htt...ipts/6e654cf7-3d68-42ea-856e-6946c35998d3-loader.js:0\n- [WARNING] The resource https://concertacaoamazonia...ttps://concerta