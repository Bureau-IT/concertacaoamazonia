rivacidade/\",\"prod_status\":200,\"dev_status\":200,\"prod_h\":18,\"dev_h\":18,\"prod_height\":9607,\"dev_height\":9607,\"Δh_pct\":0,\"Δimg_pct\":0,\"Δsec\":0,\"verdict\":\"PASS\"}]}\n### Ran Playwright code\n```js\nawait (async (page) => {\n  // Paths principais do menu (excluindo cultura/linha-do-tempo subpages e estudos individuais)\n  const paths = [\n    '/atuacao/',\n    '/atuacao/iniciativas-estruturantes/',\n    '/atuacao/grupos-de-trabalho/',\n    '/atuacao/encontros/',\n    '/atuacao/atuacao-internacional/',\n    '/atuacao/faq/',\n    '/conhecimento/',\n    '/conhecimento/espiral-de-conhecimento/',\n    '/conhecimento/mapa-das-plataformas/',\n    '/conhecimento/publicacoes/',\n    '/conhecimento/entrevistas/',\n    '/agenda-integradora/',\n    '/agenda-geral/',\n    '/contato/',\n    '/cultura/',\n    '/cultura/atlas-cultural-das-amazonias/',\n    '/aviso-de-privacidade/',\n  ];\n\n  const measurePage = async (url) => {\n    await page.context().clearCookies();\n    try {\n      const resp = await page.goto(url + '?cb=' + Date.now(), { waitUntil: 'networkidle', timeout: 30000 });\n      await page.waitForTimeout(800);\n      return await page.evaluate((status) => {\n        const headings = Array.from(document.querySelectorAll('h1, h2, h3'))\n          .map(h => h.innerText.trim().slice(0, 60))\n          .filter(Boolean);\n        const downloadBtns = Array.from(document.querySelectorAll('a, button'))\n          .filter(b => /download/i.test(b.innerText || ''))\n          .map(b => b.innerText.trim().slice(0, 30));\n        const imgsRendered = Array.from(document.querySelectorAll('img'))\n          .filter(i => i.naturalWidth >= 100).length;\n        return {\n          status,\n          page_height: document.body.scrollHeight,\n          heading_count: headings.length,\n          download_btn_count: downloadBtns.length,\n          rendered_images: imgsRendered,\n          elementor_sections: document.querySelectorAll('.elementor-section, .e-con').length,\n          headings_signature: headings.slice(0, 10).join('|').slice(0, 200),\n        };\n      }, resp ? resp.status() : 0);\n    } catch (e) {\n      return { error: (e.message || '?').slice(0, 80), status: 0 };\n    }\n  };\n\n  const results = [];\n  for (const path of paths) {\n    const prod = await measurePage('https://concertacaoamazonia.com.br' + path);\n    const dev  = await measurePage('https://concertacao.bureau-it.com' + path);\n\n    if (prod.error || dev.error || !prod.headings_signature || !dev.headings_signature) {\n      results.push({\n        path,\n        prod_status: prod.status,\n        dev_status: dev.status,\n        verdict: prod.status !== 200 && dev.status === 200 ? 'FAIL: prod-down' :\n                 dev.status !== 200 ? 'WARN: dev-down' : 'ERROR',\n      });\n      continue;\n    }\n\n    const headingsMatch = prod.headings_signature === dev.headings_signature;\n    const heightDiffPct = Math.round(Math.abs(prod.page_height - dev.page_height) / Math.max(prod.page_height, dev.page_height) * 100);\n    const imagesDiffPct = Math.round(Math.abs(prod.rendered_images - dev.rendered_images) / Math.max(prod.rendered_images, dev.rendered_images, 1) * 100);\n    const sectionsDiff  = prod.elementor_sections - dev.elementor_sections;\n    const btnsDiff      = prod.download_btn_count - dev.download_btn_count;\n\n    const fails = [];\n    if (!headingsMatch)              fails.push('headings');\n    if (heightDiffPct > 15)          fails.push(`Δh=${heightDiffPct}%`);\n    if (imagesDiffPct > 30)          fails.push(`Δimg=${imagesDiffPct}%`);\n    if (Math.abs(sectionsDiff) > 2)  fails.push(`Δsec=${sectionsDiff}`);\n    if (btnsDiff !== 0)              fails.push(`Δbtns=${btnsDiff}`);\n\n    results.push({\n      path,\n      prod_status: prod.status, dev_status: dev.status,\n      prod_h: prod.heading_count, dev_h: dev.heading_count,\n      prod_height: prod.page_height, dev_height: dev.page_height,\n      Δh_pct: heightDiffPct, Δimg_pct: imagesDiffPct, Δsec: sectionsDiff,\n      verdict: fails.length === 0 ? 'PASS' : `FAIL: ${fails.join(', ')}`,\n    });\n  }\n\n  return {\n    total: paths.length,\n    pass: results.filter(r => r.verdict === 'PASS').length,\n    fail: results.filter(r => r.verdict.startsWith('FAIL')).length,\n    error: results.filter(r => r.verdict === 'ERROR' || r.verdict.startsWith('WARN')).length,\n    results,\n  };\n})(page);\n```\n### Page\n- Page URL: https://concertacao.bureau-it.com/aviso-de-privacidade/?cb=1777686160683\n- Page Title: Aviso de Privacidade – Uma Concertação pela Amazonia\n- Console: 1 errors, 6 warnings\n### Events\n- New console entries: ../tmp/playwright-output/console-2026-05-02T01-40-18-974Z.log#L1-L7\n- [LOG] JQMIGRATE: Migrate is installed, version 3.4...-includes/js/jquery/jquery-migrate.min.js?ver=3.4.1:1\n- [LOG] TrafficSourceCookie initialized @ https://d3...ipts/6e654cf7-3d68-42ea-856e-6946c35998d3-loader.js:0\n- [LOG] FormIntegration; ver.2.0.0 initialized @ htt...ipts/6e654cf7-3d68-42ea-856e-6946c35998d3-loader.js:0\n- [LOG] [RDTracker] initialized @ https://d335luupug...ipts/6e654cf7-3d68-42ea-856e-6946c35998d3-loader.js:0\n- [LOG] JQMIGRATE: Migrate is installed with logging...wp-includes/js/jquery/jquery-migrate.js?ver=3.4.1:103\n- [LOG] JQMIGRATE: Migrate is installed, version 3.4...-includes/js/jquery/jquery-migrate.min.js?ver=3.4.1:1\n- [LOG] TrafficSourceCookie initialized @ https://d3...ipts/6e654cf7-3d68-42ea-856e-6946c35998d3-loader.js:0\n- [LOG] FormIntegration; ver.2.0.0 initialized @ htt...ipts/6e654cf7-3d68-42ea-856e-6946c35998d3-loader.js:0\n- [LOG] [RDTracker] initialized @ https://d335luupug...ipts/6e654cf7-3d68-42ea-856e-6946c35998d3-loader.js:0\n- [LOG] JQMIGRATE: Migrate is installed with logging...wp-includes/js/jquery/jquery-migrate.js?ver=3.4.1:103\n- [WARNING] JQMIGRATE: jQuery.type is deprecated @ h...wp-includes/js/jquery/jquery-migrate.js?ver=3.4.1:135\n- [LOG] JQMIGRATE: Migrate is installed, version 3.4...-incl